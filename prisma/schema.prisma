generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── 用户与团队 ──────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  avatarUrl    String?
  emailNotifications Boolean @default(true)   // 是否接收邮件通知（T3-16）
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships     TeamMember[]
  invitationsSent TeamInvitation[]
  approvals       ApprovalRecord[]
  versions        LogicNodeVersion[]
  createdNodes    LogicNode[] @relation("CreatedBy")
  updatedNodes    LogicNode[] @relation("UpdatedBy")
  notifications   Notification[]
  actorNotifications Notification[] @relation("ActorNotifications")
  apiTokens       ApiToken[]
}

model ApiToken {
  id         String    @id @default(cuid())
  name       String                          // 令牌用途描述
  tokenHash  String    @unique               // 令牌明文的 sha256，仅存哈希
  prefix     String                          // 展示用前缀，如 lmk_ab12cd34
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     TeamMember[]
  invitations TeamInvitation[]
  systems     System[]
  notifications Notification[]
}

model TeamMember {
  id        String     @id @default(cuid())
  role      TeamRole   @default(MEMBER)
  joinedAt  DateTime   @default(now())

  userId    String
  teamId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum ApprovalAction {
  SUBMIT
  APPROVE
  REJECT
  DEPRECATE
  REVOKE
}

model TeamInvitation {
  id        String           @id @default(cuid())
  email     String
  role      TeamRole         @default(MEMBER)
  status    InvitationStatus @default(PENDING)
  token     String           @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime         @default(now())

  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User     @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
}

model ApprovalRecord {
  id        String          @id @default(cuid())
  fromStatus LogicNodeStatus
  toStatus  LogicNodeStatus
  action    ApprovalAction
  comment   String?
  createdAt DateTime        @default(now())

  nodeId     String
  node       LogicNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User      @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([nodeId, createdAt])
}

// ── 核心业务模型 ─────────────────────────────────

model System {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  icon        String?  @default("layers")
  color       String?  @default("#1A56A8")
  repoUrl     String?                          // 代码仓库地址，如 https://github.com/org/repo
  repoBranch  String?                          // 默认分支，空时回退 main
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  modules     Module[]

  @@unique([teamId, slug])
  @@index([teamId])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, name: "idx_system_name_trgm")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, name: "idx_system_description_trgm")
}

model Module {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  order       Int      @default(0)
  color       String?  @default("#0F6E56")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  systemId    String
  system      System   @relation(fields: [systemId], references: [id], onDelete: Cascade)
  logicNodes  LogicNode[]
  notifications Notification[]

  @@unique([systemId, slug])
  @@index([systemId])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, name: "idx_module_name_trgm")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, name: "idx_module_description_trgm")
}

model LogicNode {
  id          String          @id @default(cuid())
  name        String                           // 节点名称，如「工单结算」
  summary     String?                          // 一句话概述
  status      LogicNodeStatus @default(DRAFT)
  priority    NodePriority    @default(NORMAL)

  // ── 6 个核心字段 ──
  trigger     String?  @db.Text              // 触发条件
  dependsOn   String?  @db.Text              // 前置依赖（文本描述）
  mainFlow    String?  @db.Text              // 主流程（富文本 JSON）
  branches    Json?                           // 分支条件列表
  edgeCases   Json?                           // 边界处理列表
  codeRef     String?                         // 代码关联（文件路径/函数名）

  // ── 图谱位置 ──
  positionX   Float    @default(0)
  positionY   Float    @default(0)

  // ── 元数据 ──
  tags        String[]
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdById String?
  updatedById String?
  createdBy   User?    @relation("CreatedBy", fields: [createdById], references: [id])
  updatedBy   User?    @relation("UpdatedBy", fields: [updatedById], references: [id])

  // 作为连线的源/目标
  outgoing    Connection[] @relation("SourceNode")
  incoming    Connection[] @relation("TargetNode")
  versions    LogicNodeVersion[]
  approvalRecords ApprovalRecord[]
  notifications Notification[]

  @@index([moduleId])
  @@index([status])
  @@index([priority])
  @@index([createdById])
  @@index([tags], type: Gin)
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, name: "idx_logic_node_name_trgm")
  @@index([summary(ops: raw("gin_trgm_ops"))], type: Gin, name: "idx_logic_node_summary_trgm")
  @@index([codeRef(ops: raw("gin_trgm_ops"))], type: Gin, name: "idx_logic_node_code_ref_trgm")
}

enum LogicNodeStatus {
  DRAFT         // 草稿
  REVIEW        // 待评审
  APPROVED      // 已确认
  DEPRECATED    // 已废弃
}

enum NodePriority {
  HIGH
  NORMAL
  LOW
}

model Connection {
  id          String         @id @default(cuid())
  label       String?
  type        ConnectionType @default(TRIGGERS)
  description String?
  createdAt   DateTime       @default(now())

  sourceId    String
  targetId    String
  source      LogicNode      @relation("SourceNode", fields: [sourceId], references: [id], onDelete: Cascade)
  target      LogicNode      @relation("TargetNode", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@index([sourceId])
  @@index([targetId])
}

enum ConnectionType {
  TRIGGERS      // A 触发 B
  DEPENDS_ON    // A 依赖 B
  BLOCKS        // A 阻断 B
  EXTENDS       // A 扩展 B
}

enum NotificationType {
  NODE_STATUS_CHANGED
  NODE_REVIEW_REQUESTED
  NODE_REVIEW_APPROVED
  NODE_REVIEW_REJECTED
  NODE_DEPRECATED
  MENTIONED_IN_NODE
  TEAM_INVITATION_RECEIVED
  TEAM_INVITATION_ACCEPTED
  TEAM_ROLE_CHANGED
  SYSTEM_BROADCAST
}

model LogicNodeVersion {
  id          String    @id @default(cuid())
  version     Int
  snapshot    Json                          // 完整节点快照
  changeNote  String?
  createdAt   DateTime  @default(now())

  nodeId      String
  node        LogicNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([nodeId, version])
}

model AiPromptVersion {
  id                 String   @id @default(cuid())
  key                String   // 例如 generate-node, nl-query
  version            Int
  variant            String   @default("default") // A/B 实验标识
  description        String?
  systemPrompt       String?  @db.Text
  userPromptTemplate String   @db.Text
  model              String   @default("claude-sonnet-4-20250514")
  temperature        Float    @default(0.2)
  maxTokens          Int      @default(2000)
  responseSchema     Json?    // Zod schema 的 JSON 表示
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())
  teamId             String?

  @@unique([key, version, variant, teamId])
  @@index([key, isDefault, teamId])
}

model ImpactAnalysisReport {
  id             String   @id @default(cuid())
  nodeId         String
  moduleId       String
  title          String
  direction      String   // downstream | upstream | both
  maxDepth       Int      @default(3)
  scope          Json     // { direct: [...], indirect: [...], thirdLevel: [...], paths: [...] }
  reportMarkdown String   @db.Text
  createdById    String?
  createdAt      DateTime @default(now())

  @@index([nodeId, createdAt(sort: Desc)])
  @@index([moduleId, createdAt(sort: Desc)])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  payload   Json?            // 扩展字段：nodeName, teamName, actorName 等

  isRead    Boolean          @default(false)
  readAt    DateTime?
  emailSent Boolean          @default(false)
  emailSentAt DateTime?

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?            @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: SetNull)

  teamId    String?
  team      Team?            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  nodeId    String?
  node      LogicNode?       @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  moduleId  String?
  module    Module?          @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt])
}
